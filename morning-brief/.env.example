# Copy this to .env.local for local development
# Or set these in Vercel dashboard for production

# Brave Search API (required for news/search)
BRAVE_API_KEY=your_brave_api_key

# Optional: Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Optional: Cron secret for securing cron endpoint
CRON_SECRET=random_secret_string

# Optional: Football data API for more detailed Arsenal stats
FOOTBALL_DATA_API_KEY=your_api_key

# Optional: OpenAI API for LLM-powered insights
OPENAI_API_KEY=sk-your_key

# Optional: Google Calendar OAuth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/calendar/callback

# Optional: OpenWeather API (uses wttr.in as fallback)
OPENWEATHER_API_KEY=your_key

# Google Calendar Integration
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a project and enable Google Calendar API
# 2. Create OAuth 2.0 credentials
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback (for local)
#    and your production domain
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# After OAuth flow, you'll receive a refresh token - save it here
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Optional: OpenAI API key for LLM-powered insights (falls back to templates if not set)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Note: Stock watchlist uses Yahoo Finance (via yahoo-finance2)
# No API key required - free real-time stock data
