# Copy this to .env.local for local development
# Or set these in Vercel dashboard for production

# Brave Search API (required for news/search)
BRAVE_API_KEY=BSABaujKs3mlDim6ZDVciOo9nNbDCh8

# Optional: Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Optional: Cron secret for securing cron endpoint
CRON_SECRET=random_secret_string

# Optional: Football data API for more detailed Arsenal stats
FOOTBALL_DATA_API_KEY=your_api_key

# Optional: OpenWeather API (uses wttr.in as fallback)
OPENWEATHER_API_KEY=your_key
